{
  "name": "pdf_buddy_electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.viger1973.pdfbuddy",
